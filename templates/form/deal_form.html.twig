{#
    Form theme for the "record a deal" form.
    - expanded choices (Contract, Bouts, Petit au bout) render as a segmented
      control; the radios stay real for a11y and form binding.
    - the Poignées / Misères collections render as fields (via form_row), which
      keeps form_rest from re-emitting them orphaned after the submit button.
      They need the participants list (announcer names / options), passed in
      through form_row: {{ form_row(form.poignees, {participants: ..., names_by_id: ...}) }}.
#}

{% block choice_widget_expanded %}
    <div class="ab-segmented" id="{{ id }}">
        {%- for child in form %}
            <label class="ab-segmented__option">
                {{- form_widget(child) -}}
                <span class="ab-segmented__label">{{ child.vars.label|trans }}</span>
            </label>
        {%- endfor %}
    </div>
{% endblock %}

{% block _record_classic_deal_form_poignees_row %}
    <fieldset
        class="form-collection"
        data-controller="form-collection"
        data-form-collection-name-prefix-value="{{ form.vars.full_name }}"
        data-form-collection-index-value="{{ form|length }}"
        data-form-collection-remove-label-value="{{ 'deal.create.poignees_remove'|trans }}"
    >
        <legend class="form-collection__legend">{{ 'deal.create.poignees_label'|trans }}</legend>

        <ul data-form-collection-target="list" class="form-collection-list">
            {% for entry in form %}
                {% set announcerId = entry.announcerId.vars.value %}
                {% set size = entry.size.vars.value %}
                <li class="form-collection-line">
                    <span class="form-collection-line__label">
                        {{ names_by_id[announcerId] is defined ? names_by_id[announcerId].name : '?' }}
                        —
                        {{ ('deal.create.poignee.size.' ~ size)|trans }}
                    </span>
                    {{ form_widget(entry.announcerId, {attr: {hidden: true}}) }}
                    {{ form_widget(entry.size, {attr: {hidden: true}}) }}
                    <button
                        type="button"
                        class="form-collection-remove"
                        aria-label="{{ 'deal.create.poignees_remove'|trans }}"
                        data-action="click->form-collection#remove"
                    >×</button>
                </li>
            {% endfor %}
        </ul>

        <button
            type="button"
            class="form-collection-add"
            data-action="click->form-collection#openModal"
        >{{ 'deal.create.poignees_add'|trans }}</button>

        <dialog data-form-collection-target="modal" class="modal">
            <article class="modal-content">
                <header class="modal-header">
                    <h2>{{ 'deal.create.poignees_add'|trans }}</h2>
                </header>
                <div class="modal-form">
                    <label class="modal-field">
                        {{ 'deal.create.poignee.announcer_label'|trans }}
                        <select data-form-collection-target="field" data-field-name="announcerId">
                            {% for participant in participants %}
                                <option value="{{ participant.id }}">{{ participant.name }}</option>
                            {% endfor %}
                        </select>
                    </label>
                    <label class="modal-field">
                        {{ 'deal.create.poignee.size_label'|trans }}
                        <select data-form-collection-target="field" data-field-name="size">
                            <option value="single">{{ 'deal.create.poignee.size.single'|trans }}</option>
                            <option value="double">{{ 'deal.create.poignee.size.double'|trans }}</option>
                            <option value="triple">{{ 'deal.create.poignee.size.triple'|trans }}</option>
                        </select>
                    </label>
                    <div class="modal-actions">
                        <button
                            type="button"
                            class="secondary"
                            data-action="click->form-collection#closeModal"
                        >{{ 'common.cancel'|trans }}</button>
                        <button
                            type="button"
                            data-action="click->form-collection#confirmAdd"
                        >{{ 'deal.create.poignees_add'|trans }}</button>
                    </div>
                </div>
            </article>
        </dialog>
    </fieldset>
{% endblock %}

