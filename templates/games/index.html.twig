{% extends 'base.html.twig' %}

{% block title %}{{ 'games.index.title'|trans }} — Abomey{% endblock %}

{% block body %}
    <section class="games-list-hero">
        <h1>{{ 'games.index.title'|trans }}</h1>
    </section>

    {% if games is empty %}
        <article class="empty-state">
            <p>{{ 'games.index.empty.message'|trans }}</p>
            <p>
                <a href="{{ path('app_game_new') }}" role="button">
                    {{ 'games.index.empty.cta'|trans }}
                </a>
            </p>
        </article>
    {% else %}
        <ul class="game-cards">
            {% for game in games %}
                <li class="game-card">
                    <a href="{{ path('app_game_show', {id: game.id}) }}" class="game-card__link">
                        <header class="game-card__header">
                            <h2 class="game-card__title">{{ game.name }}</h2>
                            <span class="game-mode-badge">{{ ('game.mode.' ~ game.mode)|trans }}</span>
                        </header>
                        {% if game.dealCount == 0 %}
                            <ul class="game-card__participants">
                                {% for participant in game.participants %}
                                    <li class="participant-chip">{{ participant.name }}</li>
                                {% endfor %}
                            </ul>
                            <p class="game-card__state muted">{{ 'games.index.no_donnes'|trans }}</p>
                        {% else %}
                            <ul class="game-card__scores">
                                {% for participant in game.participants %}
                                    <li class="game-card__score">
                                        <span class="game-card__score-name">{{ participant.name }}</span>
                                        <span class="game-card__score-value">{{ participant.cumulativeScore }}</span>
                                    </li>
                                {% endfor %}
                            </ul>
                            <p class="game-card__state muted">
                                {{ 'games.index.deal_count'|trans({'%count%': game.dealCount}, null, null) }}
                            </p>
                        {% endif %}
                    </a>
                </li>
            {% endfor %}
        </ul>
    {% endif %}
{% endblock %}
