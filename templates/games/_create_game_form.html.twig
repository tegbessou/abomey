<div {{ attributes }}>
    {% if errorKey %}
        <article class="flash flash--error">{{ errorKey|trans }}</article>
    {% endif %}

    {% if this.players() is empty %}
        <article class="empty-state">
            <p>{{ 'game.create.no_players_message'|trans }}</p>
            <p class="muted">{{ 'game.create.no_players_hint'|trans }}</p>
        </article>
    {% else %}
        {{ form_start(form, {
            'attr': {
                'class': 'game-form',
                'data-action': 'live#action:prevent',
                'data-live-action-param': 'submit',
            }
        }) }}
            {{ form_errors(form) }}

            <fieldset>
                <label for="{{ form.name.vars.id }}">{{ form.name.vars.label|trans }}</label>
                {{ form_widget(form.name) }}
                {{ form_errors(form.name) }}
            </fieldset>

            <fieldset>
                <legend>{{ 'game.create.mode_label'|trans }}</legend>
                <div class="mode-grid">
                    {% for child in form.mode %}
                        <label class="mode-option">
                            {{ form_widget(child) }}
                            <span class="mode-card">
                                <strong>{{ child.vars.label|trans }}</strong>
                                <small>{{ ('game.create.mode_' ~ (child.vars.value == '3' ? 'three' : (child.vars.value == '4' ? 'four' : 'five')) ~ '_hint')|trans }}</small>
                            </span>
                        </label>
                    {% endfor %}
                </div>
                {{ form_errors(form.mode) }}
            </fieldset>

            <fieldset
                data-controller="participant-filter"
                data-participant-filter-counter-zero-value="{{ 'game.create.participants_counter_zero'|trans }}"
                data-participant-filter-counter-one-value="{{ 'game.create.participants_counter_one'|trans }}"
                data-participant-filter-counter-many-value="{{ 'game.create.participants_counter_many'|trans }}"
            >
                <legend>{{ 'game.create.participants_label'|trans }}</legend>
                <p class="muted">{{ 'game.create.participants_hint'|trans }}</p>

                <input
                    type="search"
                    class="participant-search"
                    placeholder="{{ 'game.create.participants_search_placeholder'|trans }}"
                    data-participant-filter-target="input"
                    data-action="input->participant-filter#filter"
                >

                <p class="participant-counter muted" data-participant-filter-target="counter"></p>

                <div class="participant-list">
                    {% for child in form.participants %}
                        <label class="participant-option" data-participant-filter-target="option">
                            {{ form_widget(child) }}
                            <span>{{ child.vars.label }}</span>
                        </label>
                    {% endfor %}
                </div>

                <p class="participant-empty muted" data-participant-filter-target="empty" hidden>
                    {{ 'game.create.participants_no_match'|trans }}
                </p>

                {{ form_errors(form.participants) }}
            </fieldset>

            <button type="submit">{{ 'game.create.submit'|trans }}</button>
        {{ form_end(form) }}
    {% endif %}
</div>
