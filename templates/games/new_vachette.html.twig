{% extends 'base.html.twig' %}

{% block title %}{{ 'deal.vachette.title'|trans({'%game%': game.name}) }}{% endblock %}

{% block body %}
    {% form_theme form 'form/deal_form.html.twig' %}

    <section class="game-hero">
        <twig:badge>{{ ('game.mode.' ~ game.mode)|trans }}</twig:badge>
        <h1>{{ 'deal.vachette.title'|trans({'%game%': game.name}) }}</h1>
    </section>

    {% if errorKey is not null %}
        <p class="flash flash--error">{{ errorKey|trans }}</p>
    {% endif %}

    {{ form_start(form, {attr: {class: 'deal-form', 'data-controller': 'ranking-choice'}}) }}
        <section class="deal-form__group">
            <h2 class="deal-form__group-title">{{ 'deal.vachette.group_ranking'|trans }}</h2>
            {% if form.deadPlayerIds is defined %}
                {{ form_row(form.deadPlayerIds) }}
            {% endif %}
            {% for position in form.ranking %}
                {{ form_row(position, {label: 'deal.vachette.position'|trans({'%n%': loop.index})}) }}
            {% endfor %}
        </section>

        {{ form_row(form.submit) }}
    {{ form_end(form) }}

    <p><a href="{{ path('app_game_show', {id: game.id}) }}">← {{ 'common.back_to_game'|trans }}</a></p>
{% endblock %}
