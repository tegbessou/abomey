{% extends 'base.html.twig' %}

{% block title %}{{ game.name }} — Abomey{% endblock %}

{% block body %}
    <section class="game-hero">
        <twig:badge>{{ ('game.mode.' ~ game.mode)|trans }}</twig:badge>
        <h1>{{ game.name }}</h1>
    </section>

    <section>
        <h2>{{ 'game.show.participants_title'|trans }}</h2>
        <ul class="participant-list">
            {% for participant in game.participants %}
                <li class="participant-chip">{{ participant.name }}</li>
            {% endfor %}
        </ul>
    </section>

    <section class="deals-section">
        <div class="deals-section__header">
            <h2>{{ 'game.show.deals_title'|trans }}</h2>
            {% if game.mode in [3, 4, 5] %}
                <div class="deal-actions" data-controller="dialog">
                    <button type="button" role="button" data-action="dialog#open">
                        {{ 'game.show.add_deal'|trans }}
                    </button>

                    <dialog data-dialog-target="dialog" class="modal">
                        <article class="modal-content">
                            <header class="modal-header">
                                <h2>{{ 'game.show.add_deal'|trans }}</h2>
                            </header>
                            <div class="deal-choices">
                                <a href="{{ path('app_game_deal_new', {id: game.id}) }}" role="button">
                                    {{ 'game.show.deal_classic'|trans }}
                                </a>
                                <a href="{{ path('app_game_vachette_new', {id: game.id}) }}" role="button" class="secondary">
                                    {{ 'game.show.deal_vachette'|trans }}
                                </a>
                            </div>
                            <button type="button" class="secondary" data-action="dialog#close">
                                {{ 'common.cancel'|trans }}
                            </button>
                        </article>
                    </dialog>
                </div>
            {% endif %}
        </div>

        {% if game.deals|length == 0 %}
            <p class="muted">{{ 'game.show.deals_empty'|trans }}</p>
        {% else %}
            <div class="game-scoreboard">
                <h3 class="game-scoreboard__title">{{ 'game.show.total'|trans }}</h3>
                {% set leading_score = game.standings[0].cumulativeScore %}
                <ul class="game-scoreboard__rows">
                    {% for participant in game.standings %}
                        <li><twig:player_score_row :name="participant.name" :value="participant.cumulativeScore" :emphasis="participant.cumulativeScore == leading_score" /></li>
                    {% endfor %}
                </ul>
            </div>

            <div class="deals-list">
                {% for deal in game.deals %}
                    <twig:donne_card :position="deal.position" :scores="deal.scores" />
                {% endfor %}
            </div>

            <p>
                <a href="{{ path('app_game_last_deal_edit', {id: game.id}) }}" role="button" class="secondary">
                    {{ 'game.show.edit_last_deal'|trans }}
                </a>
            </p>

            <twig:donnes_matrix :game="game" />
        {% endif %}
    </section>

    <p><a href="{{ path('app_games_index') }}">← {{ 'common.back_to_games'|trans }}</a></p>
{% endblock %}
